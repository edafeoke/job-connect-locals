# Local Postgres (recommended for dev)
# 1. npm run db:up
# 2. npm run db:push && npm run db:seed
DATABASE_URL="postgresql://jobconnect:jobconnect@localhost:5432/jobconnect"

# Better Auth
BETTER_AUTH_SECRET="replace-with-openssl-rand-base64-32-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# Public URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth (optional for local dev)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="JobConnect Locals <noreply@jobconnect.locals>"

# File storage (Vercel Blob — recommended in production)
BLOB_READ_WRITE_TOKEN=""

# Skip env validation during Docker builds
# SKIP_ENV_VALIDATION=true
